# ─────────────────────────────────────────────
# daily-intel secrets
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────

# Anthropic (Claude Haiku)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (fallback LLM — get free key at aistudio.google.com)
GEMINI_API_KEY=

# Email — Gmail SMTP
# Use an App Password, not your real Gmail password.
# Enable at: myaccount.google.com -> Security -> App Passwords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# HaveIBeenPwned (free key at haveibeenpwned.com/API/Key)
HIBP_API_KEY=

# FRED Macro Data (free key at fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# NVD (optional — adds higher rate limit; get free key at nvd.nist.gov/developers/request-an-api-key)
NVD_API_KEY=
